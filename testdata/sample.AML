    &lt;Expression Expression="IADAS.FGS05_0201.XSSA_4001.BLKSTA#B8" /&gt;
  &lt;/CustomProperty&gt;
  &lt;CustomProperty Name="DISC_BLOCK" DataType="String" Locked="False" Visibility="Public" Overridden="True"&gt;
