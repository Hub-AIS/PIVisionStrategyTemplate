      <Attribute Name="Value" AttributeDataType="xs:string"><Value>^^^^^^^^^&lt;LineStyleData&gt;
  &lt;LineStyle Weight="0" LinePattern="Solid"&gt;
    &lt;FillStyle FillType="Solid"&gt;
      &lt;SolidFill&gt;
        &lt;FillColor R="0" G="0" B="0" A="255" /&gt;
        &lt;Transparency&gt;0&lt;/Transparency&gt;
      &lt;/SolidFill&gt;
    &lt;/FillStyle&gt;
  &lt;/LineStyle&gt;
&lt;/LineStyleData&gt;^^^&lt;FillStyleData VerticalPercentFill="100" HorizontalPercentFill="100"&gt;
  &lt;FillStyle FillType="Solid"&gt;
    &lt;SolidFill&gt;
      &lt;FillColor R="224" G="224" B="224" A="255" /&gt;
      &lt;Transparency&gt;0&lt;/Transparency&gt;
    &lt;/SolidFill&gt;
  &lt;/FillStyle&gt;
