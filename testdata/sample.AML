  &lt;PredefinedScripts&gt;
    &lt;OnShow DataTimeout="1000"&gt;InTouch:AREA_CPF = Area_CPFP;
InTouch:AREA_CPFUTL = Area_CPFU;
InTouch:AREA_WP = Area_WPAD;

'**************************************  ACCESS LEVEL SCRIPT **************************************
if (Area_CPFP and InTouch:CPF_usergroup) or (Area_CPFU and InTouch:CPFUTL_usergroup) or (Area_WPAD and InTouch:Wellpad_usergroup) then

 		if InTouch:EngineerRole or InTouch:OperatorRole then
		EE_ACC_FLD2 = true;
		else
		EE_ACC_FLD2 = false;
		endif;

else
		EE_ACC_FLD2 = false;
endif;


'************************************************************************************************&lt;/OnShow&gt;
    &lt;WhileShowing TriggerPeriodMS="1000"&gt;'**************************************  ACCESS LEVEL SCRIPT **************************************
if (Area_CPFP and InTouch:CPF_usergroup) or (Area_CPFU and InTouch:CPFUTL_usergroup) or (Area_WPAD and InTouch:Wellpad_usergroup) then

 		if InTouch:EngineerRole or InTouch:OperatorRole then
		EE_ACC_FLD2 = true;
		else
		EE_ACC_FLD2 = false;
		endif;

else
		EE_ACC_FLD2 = false;
endif;


'************************************************************************************************&lt;/WhileShowing&gt;
    &lt;OnHide&gt;dim CursorPositionX as integer;
dim CursorPositionY as integer;

CursorPositionX = InTouch:$ObjHor;	{ To Fetch the X Co-ordinate }
CursorPositionY = InTouch:$ObjVer;	{ To Fetch the Y Co-ordinate }

IF attribute("InTouch:ZHMI-App-Montors-Layout") == "Single" then

	
	InTouch:M1_COMPBLOCKNAME1 = ""; 
	InTouch:EE_OverlayPosition_M1_LR = "";
	HideGraphic("M1_LR");
	InTouch:EE_TrendPosition_M1_LR = "";
	HideGraphic("M1_LR1");


	InTouch:M1_COMPBLOCKNAME2 = ""; 
	InTouch:EE_OverlayPosition_M1_UR = "";
	HideGraphic("M1_UR");
	InTouch:EE_TrendPosition_M1_UR = "";
	HideGraphic("M1_UR1");

	InTouch:M1_COMPBLOCKNAME3 = ""; 
	InTouch:EE_OverlayPosition_M1_LL = "";
	HideGraphic("M1_LL");
	InTouch:EE_TrendPosition_M1_LL = "";
	HideGraphic("M1_LL1");

	InTouch:M1_COMPBLOCKNAME4 = ""; 
	InTouch:EE_OverlayPosition_M1_UL = "";
	HideGraphic("M1_UL");
	InTouch:EE_TrendPosition_M1_UL = "";
	HideGraphic("M1_UL1");

endif;

IF attribute("InTouch:ZHMI-App-Montors-Layout") == "Horz2" then
if CursorPositionX &amp;lt; 1920 then

	InTouch:M1_COMPBLOCKNAME1 = ""; 
	InTouch:EE_OverlayPosition_M1_LR = "";
	HideGraphic("M1_LR");
	InTouch:EE_TrendPosition_M1_LR = "";
	HideGraphic("M1_LR1");


	InTouch:M1_COMPBLOCKNAME2 = ""; 
	InTouch:EE_OverlayPosition_M1_UR = "";
	HideGraphic("M1_UR");
	InTouch:EE_TrendPosition_M1_UR = "";
	HideGraphic("M1_UR1");

	InTouch:M1_COMPBLOCKNAME3 = ""; 
	InTouch:EE_OverlayPosition_M1_LL = "";
	HideGraphic("M1_LL");
	InTouch:EE_TrendPosition_M1_LL = "";
	HideGraphic("M1_LL1");

	InTouch:M1_COMPBLOCKNAME4 = ""; 
	InTouch:EE_OverlayPosition_M1_UL = "";
	HideGraphic("M1_UL");
	InTouch:EE_TrendPosition_M1_UL = "";
