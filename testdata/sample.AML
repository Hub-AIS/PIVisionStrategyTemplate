  &lt;PredefinedScripts&gt;
    &lt;WhileShowing TriggerPeriodMS="50"&gt;{dim span as real;
span =abs(HSCO1-LSCO1);
IF span &amp;lt;= 1 then
_format="#.###";
elseif span &amp;lt;= 10 then
_Format="##.##";
elseif span &amp;lt;= 100 then
_Format="###.#";
elseif span &amp;lt;= 999 then
_Format="###";
else
_Format="###";
endif;
PV.TextFormat = _Format;}


&lt;/WhileShowing&gt;
  &lt;/PredefinedScripts&gt;
  &lt;NamedScripts&gt;
    &lt;NamedScript Name="Alarm_detection" DeadBand="0"&gt;
      &lt;ScriptExpression Expression="BAD + H*2 + L*3 + UNACK*4" /&gt;
      &lt;Script&gt;
        &lt;ValueChange&gt;if (BAD == 1)
then FROM_BAD = 1;
FROM_H = 0;
FROM_L = 0;
elseif (H == 1)
then FROM_H = 1;
FROM_BAD = 0;
FROM_L = 0;
elseif (L == 1)
then FROM_L = 1;
FROM_BAD = 0;
FROM_H = 0;
endif;

if (UNACK == 0)
then
FROM_BAD = 0;
FROM_H = 0;
FROM_L = 0;
endif;



if ((L_MASK == 1 and not FROM_BAD and not FROM_H) or (H_MASK==1 and not FROM_BAD and not FROM_L) or MAINT==1)
then
UNACK = 0;
endif;
&lt;/ValueChange&gt;
