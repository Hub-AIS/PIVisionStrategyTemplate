  &lt;/CustomProperty&gt;
  &lt;CustomProperty Name="FAULT_UNACK" DataType="Boolean" Locked="False" Visibility="Public" Overridden="True"&gt;
    &lt;Expression Expression="IADAS.FGS05_0201.XSSD_4001.UNACK" /&gt;
  &lt;/CustomProperty&gt;
  &lt;CustomProperty Name="FLT_BLOCK" DataType="String" Locked="False" Visibility="Public" Overridden="True"&gt;
