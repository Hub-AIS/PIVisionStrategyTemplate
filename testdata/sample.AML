  &lt;NamedScripts&gt;
    &lt;NamedScript Name="Alarm_detection" DeadBand="0"&gt;
      &lt;ScriptExpression Expression="BAD + H*2 + L*3 + UNACK*4" /&gt;
      &lt;Script&gt;
        &lt;ValueChange&gt;if (BAD == 1)
then FROM_BAD = 1;
FROM_H = 0;
FROM_L = 0;
elseif (H == 1)
then FROM_H = 1;
FROM_BAD = 0;
FROM_L = 0;
elseif (L == 1)
then FROM_L = 1;
FROM_BAD = 0;
FROM_H = 0;
endif;

if (UNACK == 0)
then
FROM_BAD = 0;
FROM_H = 0;
FROM_L = 0;
endif;

if ((L_MASK == 1 and not FROM_BAD and not FROM_H) or (H_MASK==1 and not FROM_BAD and not FROM_L) or MAINT==1)
then
UNACK = 0;
endif;
&lt;/ValueChange&gt;
      &lt;/Script&gt;
    &lt;/NamedScript&gt;
    &lt;NamedScript Name="Normal_mode" DeadBand="0"&gt;
      &lt;ScriptExpression Expression="MA or LR" /&gt;
      &lt;Script&gt;
        &lt;ValueChange&gt;if MA==0 and NORMAL_MODE ==0 then
ABNORMAL=FALSE;
elseif MA==1 and NORMAL_MODE ==1 
then ABNORMAL=FALSE;
elseif LR==1 and NORMAL_MODE ==2 
then ABNORMAL=FALSE;
else
ABNORMAL=TRUE;
ENDIF;
&lt;/ValueChange&gt;
      &lt;/Script&gt;
    &lt;/NamedScript&gt;
  &lt;/NamedScripts&gt;
