      &lt;Script&gt;
        &lt;WhileTrue TriggerPeriodMS="50"&gt;dim span as real;
span =abs(HIGHLIMIT-LOWLIMIT);
IF span &amp;lt;= 1 then
_format="#.###";
elseif span &amp;lt;= 10 then
_Format="##.##";
elseif span &amp;lt;= 100 then
_Format="###.#";
elseif span &amp;lt;= 999 then
_Format="###";
else
_Format="###";
endif;
PV.TextFormat = _Format;&lt;/WhileTrue&gt;
