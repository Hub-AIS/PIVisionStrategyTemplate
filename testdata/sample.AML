&lt;/LineStyleData&gt;^^^&lt;FillStyleData VerticalPercentFill="100" HorizontalPercentFill="100"&gt;
  &lt;FillStyle FillType="Solid"&gt;
    &lt;SolidFill&gt;
      &lt;FillColor R="150" G="150" B="150" A="255" /&gt;
      &lt;Transparency&gt;0&lt;/Transparency&gt;
    &lt;/SolidFill&gt;
  &lt;/FillStyle&gt;
  &lt;UnfilledStyle FillType="Solid"&gt;
    &lt;SolidFill&gt;
      &lt;FillColor R="0" G="0" B="0" A="255" /&gt;
      &lt;Transparency&gt;0&lt;/Transparency&gt;
    &lt;/SolidFill&gt;
  &lt;/UnfilledStyle&gt;
  &lt;FillBehavior&gt;Both&lt;/FillBehavior&gt;
  &lt;HorizontalDirection&gt;Right&lt;/HorizontalDirection&gt;
